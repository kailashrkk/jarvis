"""
server.py -- WebSocket bridge between Jarvis and the browser UI.

Jarvis calls set_state() to push state changes to all connected browsers.
Browser sends {type: tap} messages when the orb is tapped.
"""

import asyncio
import json
import threading
import websockets

PORT = 8765
_clients = set()
_tap_callback = None
_loop = None


async def _handler(ws):
    _clients.add(ws)
    try:
        async for msg in ws:
            try:
                data = json.loads(msg)
                if data.get('type') == 'tap' and _tap_callback:
                    threading.Thread(target=_tap_callback, daemon=True).start()
            except Exception:
                pass
    except Exception:
        pass
    finally:
        _clients.discard(ws)


async def _broadcast(payload):
    if _clients:
        msg = json.dumps(payload)
        await asyncio.gather(*[c.send(msg) for c in list(_clients)], return_exceptions=True)


def set_state(state: str, response: str = None, battery: int = None):
    """Call from Jarvis to update the UI."""
    payload = {'state': state}
    if response is not None:
        payload['response'] = response
    if battery is not None:
        payload['battery'] = battery
    if _loop and not _loop.is_closed():
        asyncio.run_coroutine_threadsafe(_broadcast(payload), _loop)


def set_tap_callback(fn):
    global _tap_callback
    _tap_callback = fn


def start():
    """Start the WebSocket server in a background thread."""
    global _loop

    def run():
        global _loop
        _loop = asyncio.new_event_loop()
        asyncio.set_event_loop(_loop)
        _loop.run_until_complete(
            websockets.serve(_handler, 'localhost', PORT)
        )
        print(f'[server] WebSocket running on ws://localhost:{PORT}')
        _loop.run_forever()

    t = threading.Thread(target=run, daemon=True)
    t.start()
